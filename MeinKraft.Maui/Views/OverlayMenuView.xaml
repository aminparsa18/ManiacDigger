<?xml version="1.0" encoding="utf-8" ?>
<!--
    OverlayMenuView.xaml
    ════════════════════
    Pause / options overlay extracted from GameView.
    Host it as a second layer in GameView's root Grid; toggle IsVisible from GameView's
    code-behind.  All event handlers live in OverlayMenuView.xaml.cs.
-->
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MeinKraft.Maui.Views.OverlayMenuView">

    <ContentView.Resources>
        <ResourceDictionary>

            <!-- ── Palette ──────────────────────────────────────────────── -->
            <Color x:Key="StoneEdgeTop">#aaaaaa</Color>
            <Color x:Key="StoneEdgeBottom">#2a2a2a</Color>
            <Color x:Key="GrassGreen">#5d9e29</Color>
            <Color x:Key="TextWhite">#f0ece0</Color>
            <Color x:Key="TextDim">#aaaaaa</Color>
            <Color x:Key="ToggleActiveTop">#6ab830</Color>
            <Color x:Key="ToggleActiveBottom">#3a6a10</Color>
            <Color x:Key="ToggleInactiveTop">#666666</Color>
            <Color x:Key="ToggleInactiveBottom">#333333</Color>

            <!-- ── Shared drop-shadow ────────────────────────────────────── -->
            <Shadow x:Key="BlockShadow" Brush="#000000" Offset="4,4" Radius="0" Opacity="0.85" />

            <!-- ── Bevel border — stone buttons & rows ───────────────────── -->
            <Style x:Key="VoxelButtonBevel" TargetType="Border">
                <Setter Property="StrokeThickness"   Value="0" />
                <Setter Property="Padding"           Value="3" />
                <Setter Property="HorizontalOptions" Value="Center" />
                <Setter Property="Shadow"            Value="{StaticResource BlockShadow}" />
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="{StaticResource StoneEdgeTop}"    Offset="0.0" />
                            <GradientStop Color="{StaticResource StoneEdgeBottom}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── Standard stone button face ───────────────────────────── -->
            <Style x:Key="VoxelButton" TargetType="Button">
                <Setter Property="FontFamily"    Value="PressStart2PRegular" />
                <Setter Property="FontSize"      Value="9" />
                <Setter Property="TextColor"     Value="{StaticResource TextWhite}" />
                <Setter Property="WidthRequest"  Value="310" />
                <Setter Property="HeightRequest" Value="40" />
                <Setter Property="CornerRadius"  Value="0" />
                <Setter Property="BorderWidth"   Value="0" />
                <Setter Property="Padding"       Value="0" />
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#9a9a9a" Offset="0.0"  />
                            <GradientStop Color="#6b6b6b" Offset="0.45" />
                            <GradientStop Color="#595959" Offset="0.55" />
                            <GradientStop Color="#404040" Offset="1.0"  />
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── Bevel border shared by toggle pair and stepper arrows ─── -->
            <!--
                Thin 2px stone bevel — wraps the [ON][OFF] pair as a single
                segmented-control unit, or a single stepper arrow.
            -->
            <Style x:Key="ToggleBevel" TargetType="Border">
                <Setter Property="StrokeThickness"   Value="0" />
                <Setter Property="Padding"           Value="2" />
                <Setter Property="HorizontalOptions" Value="Center" />
                <Setter Property="VerticalOptions"   Value="Center" />
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="{StaticResource StoneEdgeTop}"    Offset="0.0" />
                            <GradientStop Color="{StaticResource StoneEdgeBottom}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── Toggle segment — active (green) ──────────────────────── -->
            <Style x:Key="ToggleBtnActive" TargetType="Button">
                <Setter Property="FontFamily"    Value="PressStart2PRegular" />
                <Setter Property="FontSize"      Value="7" />
                <Setter Property="TextColor"     Value="{StaticResource TextWhite}" />
                <Setter Property="WidthRequest"  Value="52" />
                <Setter Property="HeightRequest" Value="32" />
                <Setter Property="CornerRadius"  Value="0" />
                <Setter Property="BorderWidth"   Value="0" />
                <Setter Property="Padding"       Value="0" />
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="{StaticResource ToggleActiveTop}"    Offset="0.0"  />
                            <GradientStop Color="{StaticResource ToggleActiveBottom}" Offset="1.0"  />
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── Toggle segment — inactive (stone) ────────────────────── -->
            <Style x:Key="ToggleBtnInactive" TargetType="Button">
                <Setter Property="FontFamily"    Value="PressStart2PRegular" />
                <Setter Property="FontSize"      Value="7" />
                <Setter Property="TextColor"     Value="{StaticResource TextDim}" />
                <Setter Property="WidthRequest"  Value="52" />
                <Setter Property="HeightRequest" Value="32" />
                <Setter Property="CornerRadius"  Value="0" />
                <Setter Property="BorderWidth"   Value="0" />
                <Setter Property="Padding"       Value="0" />
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="{StaticResource ToggleInactiveTop}"    Offset="0.0"  />
                            <GradientStop Color="{StaticResource ToggleInactiveBottom}" Offset="1.0"  />
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── Stepper arrow button (◀ / ▶) ─────────────────────────── -->
            <Style x:Key="StepperBtn" TargetType="Button">
                <Setter Property="FontFamily"    Value="PressStart2PRegular" />
                <Setter Property="FontSize"      Value="9" />
                <Setter Property="TextColor"     Value="{StaticResource TextWhite}" />
                <Setter Property="WidthRequest"  Value="38" />
                <Setter Property="HeightRequest" Value="32" />
                <Setter Property="CornerRadius"  Value="0" />
                <Setter Property="BorderWidth"   Value="0" />
                <Setter Property="Padding"       Value="0" />
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#9a9a9a" Offset="0.0"  />
                            <GradientStop Color="#404040" Offset="1.0"  />
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── Option row label ──────────────────────────────────────── -->
            <Style x:Key="OptionLabel" TargetType="Label">
                <Setter Property="FontFamily"            Value="PressStart2PRegular" />
                <Setter Property="FontSize"              Value="7" />
                <Setter Property="TextColor"             Value="{StaticResource TextWhite}" />
                <Setter Property="VerticalOptions"       Value="Center" />
                <Setter Property="HorizontalOptions"     Value="Start" />
                <Setter Property="CharacterSpacing"      Value="1" />
            </Style>

            <!-- ── Option row container ──────────────────────────────────── -->
            <!--
                Each option row is a full-width stone-bevelled Border wrapping a
                two-column Grid: [label | control].
            -->
            <Style x:Key="OptionRowBevel" TargetType="Border">
                <Setter Property="StrokeThickness"   Value="0" />
                <Setter Property="Padding"           Value="2" />
                <Setter Property="Margin"            Value="0,0,0,6" />
                <Setter Property="Shadow"            Value="{StaticResource BlockShadow}" />
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#6a6a6a" Offset="0.0" />
                            <GradientStop Color="#2e2e2e" Offset="1.0" />
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── Grass-green divider ───────────────────────────────────── -->
            <Style x:Key="Divider" TargetType="BoxView">
                <Setter Property="HeightRequest"     Value="2" />
                <Setter Property="HorizontalOptions" Value="Fill" />
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent"                Offset="0.0" />
                            <GradientStop Color="{StaticResource GrassGreen}" Offset="0.5" />
                            <GradientStop Color="Transparent"                Offset="1.0" />
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </ContentView.Resources>

    <!--
        Root fills the entire page area (same as OverlayRoot did in GameView).
        The host (GameView) controls IsVisible on this ContentView.
    -->
    <Grid>

        <!-- ── Dim backdrop ──────────────────────────────────────────────── -->
        <BoxView HorizontalOptions="Fill" VerticalOptions="Fill"
                 InputTransparent="True">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#88000000" Offset="0.0" />
                    <GradientStop Color="#bb000000" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- ════════════════════════════════════════════════════════════════ -->
        <!-- PAUSE PANEL                                                      -->
        <!-- ════════════════════════════════════════════════════════════════ -->
        <VerticalStackLayout x:Name="PausePanel"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Spacing="0">

            <Label Text="PAUSED"
                   FontFamily="PressStart2PRegular"
                   FontSize="22"
                   TextColor="{StaticResource TextWhite}"
                   HorizontalOptions="Center"
                   CharacterSpacing="6"
                   Margin="0,0,0,4">
                <Label.Shadow>
                    <Shadow Brush="#000000" Offset="3,3" Radius="0" Opacity="1" />
                </Label.Shadow>
            </Label>

            <BoxView Style="{StaticResource Divider}" Margin="0,12,0,20" WidthRequest="220" />

            <!-- Return to Game -->
            <Border Style="{StaticResource VoxelButtonBevel}" Margin="0,0,0,8">
                <Button Style="{StaticResource VoxelButton}"
                        Text="Return to Game"
                        Clicked="OnReturnToGameClicked" />
            </Border>

            <!-- Options -->
            <Border Style="{StaticResource VoxelButtonBevel}" Margin="0,0,0,8">
                <Button Style="{StaticResource VoxelButton}"
                        Text="Options"
                        Clicked="OnOptionsClicked" />
            </Border>

            <BoxView Style="{StaticResource Divider}" Margin="0,4,0,4" WidthRequest="220" />

            <!-- Exit to Menu — redstone bevel -->
            <Border Margin="0,4,0,0"
                    StrokeThickness="0"
                    Padding="3"
                    HorizontalOptions="Center">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="4,4" Radius="0" Opacity="0.85" />
                </Border.Shadow>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#8a7070" Offset="0.0" />
                        <GradientStop Color="#2a1a1a" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Button Style="{StaticResource VoxelButton}"
                        Text="Exit to Menu"
                        Clicked="OnExitToMenuClicked">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#8a5050" Offset="0.0"  />
                            <GradientStop Color="#5a2a2a" Offset="0.45" />
                            <GradientStop Color="#4a1a1a" Offset="0.55" />
                            <GradientStop Color="#301010" Offset="1.0"  />
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
            </Border>

        </VerticalStackLayout>

        <!-- ════════════════════════════════════════════════════════════════ -->
        <!-- OPTIONS PANEL                                                    -->
        <!-- ════════════════════════════════════════════════════════════════ -->
        <!--
            Wrapped in a ScrollView so it degrades gracefully on small screens.
            WidthRequest="480" on the inner stack fixes all row widths uniformly.
        -->
        <ScrollView x:Name="OptionsPanel"
                    IsVisible="False"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    MaximumHeightRequest="580">

            <VerticalStackLayout WidthRequest="480" Spacing="0" Padding="0,24">

                <!-- ── Title ────────────────────────────────────────────── -->
                <Label Text="OPTIONS"
                       FontFamily="PressStart2PRegular"
                       FontSize="18"
                       TextColor="{StaticResource GrassGreen}"
                       HorizontalOptions="Center"
                       CharacterSpacing="6"
                       Margin="0,0,0,2">
                    <Label.Shadow>
                        <Shadow Brush="#000000" Offset="3,3" Radius="0" Opacity="1" />
                    </Label.Shadow>
                </Label>
                <Label Text="graphics &amp; gameplay"
                       FontFamily="PressStart2PRegular"
                       FontSize="6"
                       TextColor="{StaticResource TextDim}"
                       HorizontalOptions="Center"
                       CharacterSpacing="2"
                       Margin="0,0,0,16" />

                <BoxView Style="{StaticResource Divider}" Margin="0,0,0,18" />

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- Each option row:                                         -->
                <!--   Border (OptionRowBevel)                                -->
                <!--     Grid [label | toggle/stepper]  Padding="14,8"       -->
                <!-- ═══════════════════════════════════════════════════════ -->

                <!-- ── Smooth Shadows ───────────────────────────────────── -->
                <!--
                    Code-behind helper: SetToggle(BtnSmoothOn, BtnSmoothOff, value)
                    applies ToggleBtnActive/ToggleBtnInactive styles accordingly.
                -->
                <Border Style="{StaticResource OptionRowBevel}">
                    <Grid ColumnDefinitions="*,Auto" Padding="14,8">
                        <Label Grid.Column="0" Text="SMOOTH SHADOWS"
                               Style="{StaticResource OptionLabel}" />
                        <Border Grid.Column="1" Style="{StaticResource ToggleBevel}">
                            <HorizontalStackLayout Spacing="1">
                                <Button x:Name="BtnSmoothOn"
                                        Style="{StaticResource ToggleBtnActive}"
                                        Text="ON"
                                        Clicked="OnSmoothShadowsOnClicked" />
                                <Button x:Name="BtnSmoothOff"
                                        Style="{StaticResource ToggleBtnInactive}"
                                        Text="OFF"
                                        Clicked="OnSmoothShadowsOffClicked" />
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>
                </Border>

                <!-- ── Darken Sides ─────────────────────────────────────── -->
                <Border Style="{StaticResource OptionRowBevel}">
                    <Grid ColumnDefinitions="*,Auto" Padding="14,8">
                        <Label Grid.Column="0" Text="DARKEN SIDES"
                               Style="{StaticResource OptionLabel}" />
                        <Border Grid.Column="1" Style="{StaticResource ToggleBevel}">
                            <HorizontalStackLayout Spacing="1">
                                <Button x:Name="BtnDarkenOn"
                                        Style="{StaticResource ToggleBtnActive}"
                                        Text="ON"
                                        Clicked="OnDarkenSidesOnClicked" />
                                <Button x:Name="BtnDarkenOff"
                                        Style="{StaticResource ToggleBtnInactive}"
                                        Text="OFF"
                                        Clicked="OnDarkenSidesOffClicked" />
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>
                </Border>

                <!-- ── Fullscreen ───────────────────────────────────────── -->
                <Border Style="{StaticResource OptionRowBevel}">
                    <Grid ColumnDefinitions="*,Auto" Padding="14,8">
                        <Label Grid.Column="0" Text="FULLSCREEN"
                               Style="{StaticResource OptionLabel}" />
                        <Border Grid.Column="1" Style="{StaticResource ToggleBevel}">
                            <HorizontalStackLayout Spacing="1">
                                <Button x:Name="BtnFullscreenOn"
                                        Style="{StaticResource ToggleBtnInactive}"
                                        Text="ON"
                                        Clicked="OnFullscreenOnClicked" />
                                <Button x:Name="BtnFullscreenOff"
                                        Style="{StaticResource ToggleBtnActive}"
                                        Text="OFF"
                                        Clicked="OnFullscreenOffClicked" />
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>
                </Border>

                <!-- ── Server Textures ──────────────────────────────────── -->
                <Border Style="{StaticResource OptionRowBevel}">
                    <Grid ColumnDefinitions="*,Auto" Padding="14,8">
                        <Label Grid.Column="0" Text="SERVER TEXTURES"
                               Style="{StaticResource OptionLabel}" />
                        <Border Grid.Column="1" Style="{StaticResource ToggleBevel}">
                            <HorizontalStackLayout Spacing="1">
                                <Button x:Name="BtnServerTexOn"
                                        Style="{StaticResource ToggleBtnActive}"
                                        Text="ON"
                                        Clicked="OnServerTexturesOnClicked" />
                                <Button x:Name="BtnServerTexOff"
                                        Style="{StaticResource ToggleBtnInactive}"
                                        Text="OFF"
                                        Clicked="OnServerTexturesOffClicked" />
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>
                </Border>

                <!-- ── Sound ────────────────────────────────────────────── -->
                <Border Style="{StaticResource OptionRowBevel}">
                    <Grid ColumnDefinitions="*,Auto" Padding="14,8">
                        <Label Grid.Column="0" Text="SOUND"
                               Style="{StaticResource OptionLabel}" />
                        <Border Grid.Column="1" Style="{StaticResource ToggleBevel}">
                            <HorizontalStackLayout Spacing="1">
                                <Button x:Name="BtnSoundOn"
                                        Style="{StaticResource ToggleBtnActive}"
                                        Text="ON"
                                        Clicked="OnSoundOnClicked" />
                                <Button x:Name="BtnSoundOff"
                                        Style="{StaticResource ToggleBtnInactive}"
                                        Text="OFF"
                                        Clicked="OnSoundOffClicked" />
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>
                </Border>

                <!-- ── Auto Jump ────────────────────────────────────────── -->
                <Border Style="{StaticResource OptionRowBevel}">
                    <Grid ColumnDefinitions="*,Auto" Padding="14,8">
                        <Label Grid.Column="0" Text="AUTO JUMP"
                               Style="{StaticResource OptionLabel}" />
                        <Border Grid.Column="1" Style="{StaticResource ToggleBevel}">
                            <HorizontalStackLayout Spacing="1">
                                <Button x:Name="BtnAutoJumpOn"
                                        Style="{StaticResource ToggleBtnActive}"
                                        Text="ON"
                                        Clicked="OnAutoJumpOnClicked" />
                                <Button x:Name="BtnAutoJumpOff"
                                        Style="{StaticResource ToggleBtnInactive}"
                                        Text="OFF"
                                        Clicked="OnAutoJumpOffClicked" />
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>
                </Border>

                <!-- ── Resolution (stepper) ─────────────────────────────── -->
                <!--
                    _resolutions[] in code-behind:
                    { "1280×720", "1366×768", "1600×900", "1920×1080", "2560×1440", "3840×2160" }
                    OnResolutionPrevClicked / OnResolutionNextClicked cycle the index
                    and write to LblResolution.Text.
                -->
                <Border Style="{StaticResource OptionRowBevel}">
                    <Grid ColumnDefinitions="*,Auto" Padding="14,8">
                        <Label Grid.Column="0" Text="RESOLUTION"
                               Style="{StaticResource OptionLabel}" />
                        <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                            <Border Style="{StaticResource ToggleBevel}">
                                <Button Style="{StaticResource StepperBtn}"
                                        Text="◀"
                                        Clicked="OnResolutionPrevClicked" />
                            </Border>
                            <Label x:Name="LblResolution"
                                   Text="1920×1080"
                                   FontFamily="PressStart2PRegular"
                                   FontSize="7"
                                   TextColor="{StaticResource TextWhite}"
                                   WidthRequest="110"
                                   HorizontalTextAlignment="Center"
                                   VerticalOptions="Center">
                                <Label.Shadow>
                                    <Shadow Brush="#000000" Offset="2,2" Radius="0" Opacity="0.9" />
                                </Label.Shadow>
                            </Label>
                            <Border Style="{StaticResource ToggleBevel}">
                                <Button Style="{StaticResource StepperBtn}"
                                        Text="▶"
                                        Clicked="OnResolutionNextClicked" />
                            </Border>
                        </HorizontalStackLayout>
                    </Grid>
                </Border>

                <!-- ── Divider above back button ────────────────────────── -->
                <BoxView Style="{StaticResource Divider}" Margin="0,16,0,16" />

                <!-- ── Back button ──────────────────────────────────────── -->
                <Border StrokeThickness="0"
                        Padding="3"
                        HorizontalOptions="Center"
                        Shadow="{StaticResource BlockShadow}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="{StaticResource StoneEdgeTop}"    Offset="0.0" />
                            <GradientStop Color="{StaticResource StoneEdgeBottom}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Button Style="{StaticResource VoxelButton}"
                            WidthRequest="460"
                            Text="◀  Back to Menu"
                            Clicked="OnOptionsBackClicked" />
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentView>
